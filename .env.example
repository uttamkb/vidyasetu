# =============================================================
# VidyaSetu — Environment Variables
# Copy this file to .env.local and fill in your credentials
# =============================================================

# ---------------- Database (Neon PostgreSQL) ----------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/vidyasetu?sslmode=require"
# With Prisma Accelerate (optional, for connection pooling):
# PRISMA_ACCELERATE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY"

# ---------------- Authentication (NextAuth v5) ---------------
AUTH_SECRET="your-random-secret-min-32-chars"
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
NEXTAUTH_URL="http://localhost:3000"

# ---------------- Google Gemini AI --------------------------
GEMINI_API_KEY="your-gemini-api-key"
# Get your key at: https://aistudio.google.com/app/apikey

# ---------------- File Storage (for PDFs/Worksheets) --------
# Vercel Blob (recommended for Vercel deployments):
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
# OR AWS S3:
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_REGION="ap-south-1"
# AWS_S3_BUCKET="vidyasetu-content"
