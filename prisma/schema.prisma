generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Auth.js v5 Required Models
// ============================================================

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================================
// User
// ============================================================

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  name                String?
  image               String?

  // Academic profile (CBSE only for MVP)
  grade               String    @default("9")
  board               String    @default("CBSE")

  // Location (for leaderboard scoping)
  state               String?
  district            String?
  school              String?

  // Role
  role                String    @default("STUDENT") // "STUDENT" | "ADMIN"

  // Leaderboard
  leaderboardOptIn    Boolean   @default(false)

  // Onboarding
  isOnboarded         Boolean   @default(false)
  hardestSubjects     String[]
  targetScore         Int?
  studyTimePreference String?

  // Gamification
  xp                  Int       @default(0)
  level               String    @default("Beginner") // Beginner, Scholar, Topper, Board Ready

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Auth.js
  accounts            Account[]
  sessions            Session[]

  // Learning
  userMastery         UserMastery[]
  practiceSessions    PracticeSession[]
  studyStreak         StudyStreak?
  notifications       Notification[]
  userChallenges      UserChallenge[]
  submissions         Submission[]
  userBadges          UserBadge[]
  leaderboardEntries  LeaderboardEntry[]

  @@map("users")
}

// ============================================================
// Curriculum Graph  (Subject → Chapter → Topic → Subtopic)
// ============================================================

model Subject {
  id         String    @id @default(uuid())
  name       String
  grade      String    @default("9")
  board      String    @default("CBSE")
  color      String    @default("bg-blue-500")
  icon       String?
  orderIndex Int       @default(0)

  chapters       Chapter[]
  assignments    Assignment[]
  studyMaterials StudyMaterial[]

  @@unique([name, grade, board])
  @@map("subjects")
}

model Chapter {
  id         String   @id @default(uuid())
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  name       String
  orderIndex Int      @default(0)

  topics         Topic[]
  assignments    Assignment[]
  studyMaterials StudyMaterial[]

  @@unique([subjectId, name])
  @@map("chapters")
}

model Topic {
  id        String   @id @default(uuid())
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  name      String
  orderIndex Int     @default(0)

  subtopics      Subtopic[]
  studyMaterials StudyMaterial[]

  // Prerequisites
  prerequisites Topic[] @relation("TopicPrerequisites")
  requiredFor   Topic[] @relation("TopicPrerequisites")

  @@unique([chapterId, name])
  @@map("topics")
}

model Subtopic {
  id          String   @id @default(uuid())
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  name        String
  description String?
  difficulty  Int      @default(1) // 1-5
  orderIndex  Int      @default(0)

  questions   Question[]
  userMastery UserMastery[]

  @@unique([topicId, name])
  @@map("subtopics")
}

// ============================================================
// Questions (First-class entities)
// ============================================================

enum QuestionType {
  MCQ
  SHORT_ANSWER
  LONG_ANSWER
  NUMERIC
  MATCHING
}

enum BloomLevel {
  REMEMBER
  UNDERSTAND
  APPLY
  ANALYZE
}

model Question {
  id         String       @id @default(uuid())
  subtopicId String
  subtopic   Subtopic     @relation(fields: [subtopicId], references: [id], onDelete: Cascade)

  type       QuestionType
  bloomLevel BloomLevel   @default(UNDERSTAND)
  difficulty Int          @default(1) // 1-5, calibrated

  // JSON shape: { question: string, options?: string[], correctAnswer: string|number, explanation: string, maxMarks: number }
  content    Json

  // JSON shape: [{ pattern: string, explanation: string }]
  commonMisconceptions Json?

  prerequisiteIds String[] // subtopic IDs

  usageCount      Int     @default(0)
  avgAccuracy     Float   @default(0)

  source          String  @default("curated") // "curated" | "ai_generated"
  verifiedByHuman Boolean @default(false)

  sessionQuestions SessionQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subtopicId, difficulty])
  @@index([subtopicId, bloomLevel])
  @@map("questions")
}

// ============================================================
// Assignments (AI-generated or admin-created)
// ============================================================

enum AssignmentType {
  CHAPTER        // Specific chapter(s)
  SEMESTER       // Semester-level
  FULL_SYLLABUS  // All chapters
  REMEDIAL       // Targeted at weak topics
  DIAGNOSTIC     // Initial skill assessment
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
  MIXED
}

model Assignment {
  id          String         @id @default(uuid())
  title       String
  description String?

  type        AssignmentType @default(CHAPTER)
  difficulty  DifficultyLevel @default(MIXED)

  // Scope
  subjectId   String
  subject     Subject        @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  chapterId   String?        // null = semester or full syllabus
  chapter     Chapter?       @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  topicIds    String[]       // specific topic IDs

  // Questions stored as [{questionId, orderIndex}] for bank questions
  // or inline [{type, content, maxMarks}] for ad-hoc AI-generated
  questions   Json

  maxMarks    Int
  dueDate     DateTime?
  timeLimit   Int?           // minutes; null = untimed

  isAIGenerated Boolean      @default(false)
  targetGrade   String       @default("9")
  targetBoard   String       @default("CBSE")

  createdAt   DateTime       @default(now())
  submissions Submission[]

  @@index([subjectId])
  @@index([chapterId])
  @@index([targetGrade, targetBoard])
  @@map("assignments")
}

// ============================================================
// Submissions & AI Evaluation
// ============================================================

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  EVALUATED
}

model Submission {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id])

  // JSON shape: [{questionId, userAnswer, isCorrect?, marksAwarded?, aiFeedback?, correction?, explanation?}]
  answers      Json

  totalScore      Int    @default(0)
  maxMarks        Int
  percentageScore Float  @default(0)

  // AI-generated holistic feedback
  aiFeedback      String?  @db.Text

  status          SubmissionStatus @default(IN_PROGRESS)
  evaluatedAt     DateTime?
  submittedAt     DateTime         @default(now())
  timeTaken       Int?             // seconds

  @@index([userId, submittedAt])
  @@index([userId, assignmentId])
  @@map("submissions")
}

// ============================================================
// User Mastery (The Brain)
// ============================================================

model UserMastery {
  id                 String    @id @default(uuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopicId         String
  subtopic           Subtopic  @relation(fields: [subtopicId], references: [id], onDelete: Cascade)

  masteryScore       Float     @default(0)   // 0-100
  stability          Float     @default(0)   // forgetting curve stability (days)
  retrievability     Float     @default(0)   // probability of recall right now
  lastPracticed      DateTime?

  totalAttempts      Int       @default(0)
  correctAttempts    Int       @default(0)
  consecutiveCorrect Int       @default(0)

  // JSON: [{ type: string, count: number }]
  errorPatterns      Json?

  difficultyCalibration Int    @default(1)  // personalized 1-5

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([userId, subtopicId])
  @@index([userId, masteryScore])
  @@index([userId, lastPracticed])
  @@index([userId, retrievability])
  @@map("user_mastery")
}

// ============================================================
// Practice Sessions (Spaced Repetition / Adaptive)
// ============================================================

enum SessionType {
  DAILY_REVIEW
  ADAPTIVE
  TOPIC_FOCUS
  EXAM_SPRINT
  DIAGNOSTIC
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model PracticeSession {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  type           SessionType
  status         SessionStatus   @default(IN_PROGRESS)

  startTime      DateTime        @default(now())
  endTime        DateTime?
  targetDuration Int             // minutes

  interleaved    Boolean         @default(false)
  topicId        String?         // for TOPIC_FOCUS

  sessionQuestions SessionQuestion[]

  createdAt      DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([userId, status])
  @@map("practice_sessions")
}

model SessionQuestion {
  id          String          @id @default(uuid())
  sessionId   String
  session     PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  questionId  String
  question    Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  orderIndex  Int

  userAnswer  Json?
  isCorrect   Boolean?
  timeTaken   Int?            // seconds
  confidence  Int?            // 1-5
  hintsUsed   Int             @default(0)
  tutorUsed   Boolean         @default(false)

  submittedAt DateTime?

  @@unique([sessionId, orderIndex])
  @@index([sessionId, orderIndex])
  @@map("session_questions")
}

// ============================================================
// Study Materials (linked to Chapter or Topic)
// ============================================================

enum MaterialType {
  VIDEO           // YouTube link
  PDF             // Downloadable PDF
  NOTES           // Text notes
  WORKSHEET       // Practice worksheet
  PLATFORM_CONTENT // AI-generated inline content
}

model StudyMaterial {
  id          String       @id @default(uuid())
  title       String
  description String?

  type        MaterialType @default(NOTES)

  // Links
  youtubeUrl   String?      // for VIDEO type
  thumbnailUrl String?      // auto-fetched from YouTube oEmbed
  fileUrl      String?      // for PDF/WORKSHEET
  content      String?      @db.Text // for PLATFORM_CONTENT / NOTES inline

  // Curriculum link (at least one required)
  subjectId    String
  subject      Subject      @relation(fields: [subjectId], references: [id])
  chapterId    String?
  chapter      Chapter?     @relation(fields: [chapterId], references: [id])
  topicId      String?
  topic        Topic?       @relation(fields: [topicId], references: [id])

  // AI generation metadata
  isAIGenerated Boolean     @default(false)
  aiGeneratedAt DateTime?

  isPublished   Boolean     @default(true)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([subjectId])
  @@index([chapterId])
  @@index([topicId])
  @@map("study_materials")
}

// ============================================================
// Leaderboard & Ranking
// ============================================================

enum LeaderboardPeriod {
  WEEKLY
  MONTHLY
  ALL_TIME
}

model LeaderboardEntry {
  id           String            @id @default(uuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  period       String            // e.g., "2026-W18" or "2026-04" or "ALL"
  periodType   LeaderboardPeriod

  totalScore   Float             @default(0)  // avg percentage across submissions
  submissionCount Int            @default(0)

  // Ranks (null = not computed yet or user not opted-in)
  overallRank  Int?
  stateRank    Int?
  districtRank Int?
  schoolRank   Int?

  updatedAt    DateTime          @updatedAt

  @@unique([userId, period, periodType])
  @@index([periodType, period, totalScore])
  @@map("leaderboard_entries")
}

// ============================================================
// Study Streak
// ============================================================

model StudyStreak {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastStudyDate  DateTime?
  totalStudyDays Int       @default(0)

  updatedAt      DateTime  @updatedAt

  @@map("study_streaks")
}

// ============================================================
// Notifications
// ============================================================

enum NotificationType {
  BADGE
  ASSIGNMENT
  STREAK
  SCORE
  SYSTEM
  MASTERY
  REMEDIATION
  LEADERBOARD
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  read      Boolean          @default(false)
  link      String?

  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================
// Gamification: Badges & Challenges
// ============================================================

model WeeklyChallenge {
  id          String   @id @default(uuid())
  title       String
  description String
  target      Int      // e.g., complete 5 assignments
  type        String   // ASSIGNMENTS_COMPLETED, PERFECT_SCORES, MINUTES_STUDIED
  points      Int      @default(50)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)

  userChallenges UserChallenge[]

  @@map("weekly_challenges")
}

model UserChallenge {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   WeeklyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  progress    Int             @default(0)
  isCompleted Boolean         @default(false)
  completedAt DateTime?

  @@unique([userId, challengeId])
  @@map("user_challenges")
}

model Badge {
  id          String     @id @default(uuid())
  name        String     @unique
  description String
  icon        String
  category    String     // FIRST_STEPS, CONSISTENCY, MASTERY, LEADERBOARD
  condition   String   // JSON string defining unlock condition — parsed safely in gamification.ts
  points      Int        @default(10)
  createdAt   DateTime   @default(now())

  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ============================================================
// Background Tasks (Jobs Queue)
// ============================================================

model Task {
  id          String   @id @default(uuid())
  type        String   // "SEED_STUDY_MATERIAL" | "VERIFY_CURRICULUM"
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  payload     Json?    // e.g., { topicId: "..." }
  error       String?  @db.Text
  progress    Float    @default(0) // 0-100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tasks")
}
